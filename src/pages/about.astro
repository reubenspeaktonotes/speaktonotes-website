---
import BaseLayout from '../layouts/BaseLayout.astro';
import FooterSimple from '../components/FooterSimple.astro';
---

<BaseLayout title="About — SpeaktoNotes" currentPage="about">
  <main class="relative w-full overflow-hidden min-h-screen">
    <!-- Hero -->
    <div class="pt-32 pb-20 md:pt-40 md:pb-24 bg-[#0a0a0a] relative overflow-hidden">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px] pointer-events-none"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(190,242,100,0.07) 0%, transparent 70%);"></div>
      <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
        <span class="inline-flex items-center gap-1.5 uppercase text-xs font-medium text-zinc-400 tracking-widest bg-zinc-900 border border-zinc-800 rounded-full mb-8 px-3 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#BEF264] animate-pulse"></span>
          The Founder
        </span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-semibold text-white tracking-tight mb-6 leading-[1.05]">
          Built by someone who
          <span class="text-[#BEF264]">felt the pain</span>
          .
        </h1>
        <p class="text-zinc-400 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto font-light">
          SpeaktoNotes was born out of frustration — losing ideas mid-drive,
          fumbling with notes after a client meeting, watching valuable
          thoughts vanish into thin air.
        </p>
      </div>
    </div>

    <!-- Story -->
    <div class="py-20 md:py-24 bg-zinc-50">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div>
            <div class="w-full aspect-square rounded-3xl overflow-hidden relative shadow-xl">
              <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=600&fit=crop&crop=faces" alt="Founder" class="w-full h-full object-cover" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <div class="absolute bottom-5 left-5">
                <span class="inline-flex items-center gap-1.5 text-xs font-medium text-white bg-black/50 backdrop-blur-sm border border-white/10 rounded-full px-3 py-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#BEF264] animate-pulse"></span>
                  Building in public
                </span>
              </div>
            </div>
          </div>
          <div>
            <span class="inline-flex items-center gap-1.5 uppercase text-xs font-medium text-zinc-500 tracking-widest bg-zinc-100 border border-zinc-200 rounded-full mb-6 px-3 py-1.5">
              / Our Story
            </span>
            <h2 class="text-3xl md:text-4xl font-semibold text-zinc-900 tracking-tight mb-6 leading-[1.1]">
              The story behind the app.
            </h2>
            <div class="space-y-4 text-zinc-500 text-base leading-relaxed font-light">
              <p>
                It started with a simple problem: too many ideas, not enough
                time to write them all down properly. After years of
                half-finished notes and missed follow-ups, I decided to
                build the solution I always wanted.
              </p>
              <p>
                SpeaktoNotes combines the speed of voice with the power of
                AI — so every spoken word becomes a structured, searchable,
                shareable note in seconds.
              </p>
              <p>
                No complexity. No learning curve. Just speak, and let the
                app do the rest.
              </p>
            </div>
            <div class="mt-8 pt-8 border-t border-zinc-200 flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-zinc-900 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 48" fill="currentColor" class="w-4 h-8 text-[#BEF264]">
                  <rect x="4" y="12" width="4" height="24" rx="2"></rect>
                  <rect x="10" y="8" width="4" height="32" rx="2"></rect>
                  <rect x="16" y="12" width="4" height="24" rx="2"></rect>
                </svg>
              </div>
              <div>
                <p class="text-zinc-900 font-semibold text-sm">Alex Morgan</p>
                <p class="text-zinc-400 text-xs mt-0.5">Founder & CEO, SpeaktoNotes</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Numbers -->
    <div class="py-20 md:py-24 bg-white border-t border-zinc-100">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-flex items-center gap-1.5 uppercase text-xs font-medium text-zinc-500 tracking-widest bg-zinc-100 border border-zinc-200 rounded-full mb-6 px-3 py-1.5">
            / The Numbers
          </span>
          <h2 class="text-3xl md:text-5xl font-semibold text-zinc-900 tracking-tight mb-4 leading-[1.1]">
            Traction that speaks for itself.
          </h2>
          <p class="text-zinc-500 text-base md:text-lg font-light max-w-xl mx-auto">
            From a one-person project to a tool trusted by thousands — fast.
          </p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center p-6 rounded-2xl bg-zinc-50 border border-zinc-100">
            <div class="text-4xl md:text-5xl font-semibold text-zinc-900 tracking-tight leading-none mb-2">12k+</div>
            <p class="text-sm text-zinc-500 font-light">Active users</p>
          </div>
          <div class="text-center p-6 rounded-2xl bg-zinc-50 border border-zinc-100">
            <div class="text-4xl md:text-5xl font-semibold text-zinc-900 tracking-tight leading-none mb-2">40+</div>
            <p class="text-sm text-zinc-500 font-light">Languages</p>
          </div>
          <div class="text-center p-6 rounded-2xl bg-zinc-50 border border-zinc-100">
            <div class="text-4xl md:text-5xl font-semibold text-zinc-900 tracking-tight leading-none mb-2">99.8%</div>
            <p class="text-sm text-zinc-500 font-light">Accuracy rate</p>
          </div>
          <div class="text-center p-6 rounded-2xl bg-zinc-50 border border-zinc-100">
            <div class="text-4xl md:text-5xl font-semibold text-zinc-900 tracking-tight leading-none mb-2">4.9★</div>
            <p class="text-sm text-zinc-500 font-light">App store rating</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Values -->
    <div class="py-20 md:py-24 bg-[#0a0a0a] border-t border-zinc-800 relative">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:40px_40px] pointer-events-none"></div>
      <div class="max-w-5xl mx-auto px-6 relative">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-medium text-white tracking-tight mb-4 leading-[1.1]">
            What we stand for.
          </h2>
          <p class="text-zinc-500 text-base md:text-lg font-light max-w-xl mx-auto">
            Simple principles that guide every decision we make.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-zinc-900/40 border border-zinc-800 rounded-2xl p-7 hover:border-[#BEF264]/30 transition-colors group">
            <div class="w-10 h-10 rounded-xl bg-[#BEF264]/10 flex items-center justify-center mb-5 group-hover:bg-[#BEF264]/20 transition-colors">
              <iconify-icon icon="lucide:zap" width="20" style="color: #BEF264;"></iconify-icon>
            </div>
            <h3 class="text-white font-semibold text-lg mb-3">Speed first</h3>
            <p class="text-zinc-500 text-sm leading-relaxed font-light">
              Every second counts. We obsess over latency so you never lose
              your train of thought.
            </p>
          </div>
          <div class="bg-zinc-900/40 border border-zinc-800 rounded-2xl p-7 hover:border-[#BEF264]/30 transition-colors group">
            <div class="w-10 h-10 rounded-xl bg-[#BEF264]/10 flex items-center justify-center mb-5 group-hover:bg-[#BEF264]/20 transition-colors">
              <iconify-icon icon="lucide:shield-check" width="20" style="color: #BEF264;"></iconify-icon>
            </div>
            <h3 class="text-white font-semibold text-lg mb-3">Privacy by default</h3>
            <p class="text-zinc-500 text-sm leading-relaxed font-light">
              Your notes are yours. End-to-end encrypted and never used to
              train third-party models.
            </p>
          </div>
          <div class="bg-zinc-900/40 border border-zinc-800 rounded-2xl p-7 hover:border-[#BEF264]/30 transition-colors group">
            <div class="w-10 h-10 rounded-xl bg-[#BEF264]/10 flex items-center justify-center mb-5 group-hover:bg-[#BEF264]/20 transition-colors">
              <iconify-icon icon="lucide:heart" width="20" style="color: #BEF264;"></iconify-icon>
            </div>
            <h3 class="text-white font-semibold text-lg mb-3">Built with care</h3>
            <p class="text-zinc-500 text-sm leading-relaxed font-light">
              Every feature is shaped by real user feedback. We ship
              thoughtfully, not just fast.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Back CTA -->
    <div class="py-20 md:py-24 bg-[#0a0a0a] border-t border-zinc-800 relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle at center, rgba(190,242,100,0.05) 0%, transparent 60%);"></div>
      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="bg-zinc-900/50 border border-zinc-800 rounded-3xl p-10 md:p-16 text-center">
          <span class="inline-flex items-center gap-1.5 uppercase text-xs font-medium text-zinc-400 tracking-widest bg-zinc-900 border border-zinc-800 rounded-full mb-8 px-3 py-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-[#BEF264] animate-pulse"></span>
            Get Started Today
          </span>
          <h2 class="text-3xl md:text-5xl font-semibold text-white tracking-tight mb-4 leading-[1.1]">
            Ready to transform your notes?
          </h2>
          <p class="text-zinc-400 text-base md:text-lg font-light max-w-xl mx-auto mb-10 leading-relaxed">
            Join thousands of professionals already using SpeaktoNotes.
            Start your free 14-day trial — no credit card required.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#BEF264] text-black font-semibold text-sm hover:bg-[#d9f58c] transition-colors shadow-[0_0_24px_rgba(190,242,100,0.2)]">
              Get Started Free
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
            <a href="/" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-zinc-900 border border-zinc-800 text-zinc-300 font-medium text-sm hover:bg-zinc-800 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m15 18-6-6 6-6"></path>
              </svg>
              Back to Home
            </a>
          </div>
          <div class="flex items-center justify-center gap-6 mt-8">
            <div class="flex items-center gap-1.5 text-zinc-500 text-xs font-medium">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M20 6 9 17l-5-5"></path></svg>
              No credit card required
            </div>
            <div class="w-1 h-1 rounded-full bg-zinc-700"></div>
            <div class="flex items-center gap-1.5 text-zinc-500 text-xs font-medium">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M20 6 9 17l-5-5"></path></svg>
              Cancel anytime
            </div>
            <div class="w-1 h-1 rounded-full bg-zinc-700"></div>
            <div class="flex items-center gap-1.5 text-zinc-500 text-xs font-medium">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M20 6 9 17l-5-5"></path></svg>
              14-day free trial
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- About Footer -->
    <FooterSimple />
  </main>
</BaseLayout>
